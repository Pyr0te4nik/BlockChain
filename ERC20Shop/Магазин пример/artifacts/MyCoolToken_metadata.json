		"userdoc": {
			"kind": "user",
			"methods": {
				"approve(address,uint256)": {
					"notice": "Разрешить другому адресу тратить токены spender — кто может тратить, amount — сколько"
				},
				"constructor": {
					"notice": "Конструктор: создаём токен и сразу майнтим токены на deployer-а Параметр \"amount\" — это сколько токенов нужно напечатать в \"человеческом виде\" (например, 1000, 1000000 и т.п.) Внутри: - создаётся токен с именем \"My Cool Token\", тикером \"MCT\", 18 decimals - минтим \"amount * 10 ** decimals()\" токенов на адрес `msg.sender`"
				},
				"totalCap()": {
					"notice": "Общая максимальная эмиссия в \"целых\" токенах (без decimals) Например: 1_000_000_000 == 1 млрд токенов"
				},
				"transfer(address,uint256)": {
					"notice": "Перевести токены другому адресу"
				},
				"transferFrom(address,address,uint256)": {
					"notice": "Перевести от имени другого адреса (через approve) from — владелец, to — получатель, amount — сумма"
				}
			},
			"version": 1
